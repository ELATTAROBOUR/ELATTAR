# ─── Secrets / Sensitive config files ──────────────────────────────
# These files contain credentials (GitHub tokens, Supabase keys, etc.)
# Use the .example files as templates and keep actual values locally.
sync_config.json
**/sync_config.json
*.db
**/*.db

# ─── Build outputs / binaries ──────────────────────────────────────
/dist/
/keygen/
*.exe
*.dll
*.so
*.dylib
*.pdb
*.exp
*.lib

# ─── Logs ──────────────────────────────────────────────────────────
*.log
backup_*.log
build_verbose.log
flutter_*.log

# ─── IDE / Editor ──────────────────────────────────────────────────
.idea/
*.iml
*.ipr
*.iws
.vscode/
.atom/
.svn/
.history

# ─── OS ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

